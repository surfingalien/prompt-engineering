# Anthropic API key (required) — powers /api/chat, /api/scout, and the
# promptfoo eval suite (npm run eval)
ANTHROPIC_API_KEY=

# Disable the Scout's cross-model verification pass (default: enabled)
# SCOUT_VERIFY=0

# Helicone API key (optional) — when set, Anthropic calls route through
# Helicone's proxy for per-request cost/latency/prompt-version observability.
# Leave unset to call the Anthropic API directly.
HELICONE_API_KEY=

# Open Design API token (required)
# Generate with: openssl rand -hex 32
OD_API_TOKEN=

# Docker image to use (default: latest from Docker Hub)
OPEN_DESIGN_IMAGE=docker.io/vanjayak/open-design:latest

# Port for Open Design (default: 7456)
OPEN_DESIGN_PORT=7456

# Comma-separated allowed origins (for reverse proxy / public deployment)
OPEN_DESIGN_ALLOWED_ORIGINS=

# Container memory limit
OPEN_DESIGN_MEM_LIMIT=384m

# Node.js heap cap inside the Open Design container
NODE_OPTIONS=--max-old-space-size=192
